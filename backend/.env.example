PORT=5000

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/support_db
DB_SSL=false

# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_keysk-or-v1-afb895f5b9622c4c3f3fc8b5d57ec95d0953e12e20f1dabf64caba788b110985
# The Site URL and Site Name are recommended by OpenRouter for ranking/metrics
OPENROUTER_SITE_URL=https://openrouter.ai/workspaces/default/keys?utm_source=signup-success
OPENROUTER_SITE_NAME=OpenRouter

# Meta WhatsApp Business API
# The 'verify token' you configure in the Meta App Dashboard for webhook verification
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_API_TOKEN=your_whatsapp_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
